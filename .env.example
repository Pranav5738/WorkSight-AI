# Backend environment variables
ADMIN_USERNAME=admin
ADMIN_PASSWORD=demo123
SECOND_ADMIN=Pranav
SECOND_ADMIN_PASS=Pranav
JWT_SECRET=replace-with-a-strong-random-secret
ENABLE_PROMETHEUS=1
ENABLE_RATE_LIMIT=0
RATE_LOGIN=5/minute

# Optional: Database URL (defaults to sqlite:///./data.db stored under /app/data)
# DATABASE_URL=sqlite:////data/data.db

# Monitoring and features
# MONITORING_ENABLED=1
# REAL_FACE=0
# VBG_FOR_ATTENDANCE=1

# Frontend
# Note: For Docker builds, these are injected at build-time via build args
VITE_API_URL=http://localhost:8000
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
VITE_DEMO_USER=admin
VITE_DEMO_PASS=demo123
