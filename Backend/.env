# Toggle real face pipeline (InsightFace). Set to 1 to enable, 0 to disable.
REAL_FACE=1

# Use CPU by default for widest compatibility (-1 = CPU, 0 = first GPU)
FACE_CTX_ID=-1

# Detection model input size (width x height)
FACE_DET_SIZE=640x640

# Confidence threshold used by backend when comparing embeddings
CONFIDENCE_THRESHOLD=0.9

# Disable simulated recognition positives when embeddings are not ready (1=enabled, 0=disabled)
RECOGNITION_SIMULATION=0

# Note: Ensure optional dependencies are installed for best results:
#   pip install -r requirements-vision.txt
# If running on Python 3.12, prefer the Backend: Uvicorn (Py3.10) task which prepares a 3.10 venv
# and installs the prebuilt wheel located at the repo root: insightface-0.7.3-cp310-cp310-win_amd64.whl

# Work Activity Monitoring (set to 1 to enable API and background service controls)
MONITORING_ENABLED=1
# Optional: set explicit config path (defaults to Backend/monitoring/config.json)
# MONITORING_CONFIG=Backend/monitoring/config.json
