# Backend environment example
# Copy to Backend/.env and adjust as needed

# Use hash fallback by default; set to 1 to enable InsightFace (install deps first)
REAL_FACE=0
FACE_CTX_ID=-1
FACE_DET_SIZE=640x640
RECOGNITION_SIMULATION=0
CONFIDENCE_THRESHOLD=0.9

# Monitoring service
MONITORING_ENABLED=1
MONITORING_AUTOSTART=0
MONITORING_AUTOSTART_DEMO=0

# Virtual background for attendance preprocessing
VBG_FOR_ATTENDANCE=1
VBG_MODE=color
VBG_COLOR=200,200,200
VBG_SHORT_SIDE=256
VBG_THRESHOLD=0.1

# Database (SQLite by default)
# DATABASE_URL=sqlite:///./data.db
