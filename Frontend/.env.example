# -----------------------------
# WorkSight AI Environment
# -----------------------------
# Copy this file to .env and fill in the secrets.

# Supabase direct mode (used when VITE_API_URL is not set)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
# VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Optional custom backend API (FastAPI / etc.)
# When provided, the app will use your backend for employees, attendance, and logs.
# Keep this commented out if you want frontend-only Supabase mode.
VITE_API_URL=http://127.0.0.1:8000

# Optional AI provider keys
# VITE_GEMINI_API_KEY=your_gemini_api_key
# VITE_OPENAI_API_KEY=your_openai_api_key

# Demo auth overrides (optional)
# VITE_DEMO_USERNAME=admin
# VITE_DEMO_PASSWORD=demo123
